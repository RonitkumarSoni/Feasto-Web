// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  RESTAURANT_OWNER
  DELIVERY_PARTNER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  phone     String?  @unique
  password  String?
  googleId  String?  @unique
  appleId   String?  @unique
  name      String
  role      Role     @default(CUSTOMER)
  avatarUrl String?
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens    RefreshToken[]
  otpVerifications OtpVerification[]
  addresses        Address[]
  restaurants      Restaurant[]
  carts            Cart[]
  orders           Order[]
  deliveryPartner  DeliveryPartner?
  reviews          Review[]
  notifications    Notification[]
  auditLogs        AuditLog[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model OtpVerification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String
  type      String   // 'EMAIL' or 'PHONE'
  purpose   String   // 'REGISTER', 'LOGIN', 'FORGOT_PASSWORD'
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'HOME', 'WORK', 'OTHER'
  street    String
  city      String
  state     String
  zipCode   String
  country   String   @default("India")
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  orders    Order[]
}

model Restaurant {
  id            String   @id @default(uuid())
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id])
  name          String
  description   String?
  logoUrl       String?
  bannerUrl     String?
  address       String
  latitude      Float?
  longitude     Float?
  contactPhone  String
  contactEmail  String?
  isApproved    Boolean  @default(false)
  isActive      Boolean  @default(true)
  deliveryRadius Float   @default(5.0) // in km
  minOrderValue Float    @default(0)
  taxRate       Float    @default(5.0) // percentage
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  images        RestaurantImage[]
  categories    RestaurantCategory[]
  foods         Food[]
  orders        Order[]
  reviews       Review[]
}

model RestaurantImage {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  url          String
  caption      String?
  createdAt    DateTime   @default(now())
}

model RestaurantCategory {
  id           String     @id @default(uuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  createdAt    DateTime   @default(now())
  
  foods        Food[]
}

model Food {
  id           String             @id @default(uuid())
  restaurantId String
  restaurant   Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  categoryId   String?
  category     RestaurantCategory? @relation(fields: [categoryId], references: [id])
  name         String
  description  String?
  basePrice    Float
  isVeg        Boolean            @default(true)
  isAvailable  Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  images       FoodImage[]
  variants     FoodVariant[]
  addons       FoodAddon[]
  cartItems    CartItem[]
  orderItems   OrderItem[]
  reviews      Review[]
}

model FoodImage {
  id        String   @id @default(uuid())
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())
}

model FoodVariant {
  id        String   @id @default(uuid())
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  name      String   // e.g., 'Small', 'Medium', 'Large'
  price     Float
  createdAt DateTime @default(now())

  cartItems  CartItem[]
  orderItems OrderItem[]
}

model FoodAddon {
  id        String   @id @default(uuid())
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  name      String   // e.g., 'Extra Cheese'
  price     Float
  createdAt DateTime @default(now())

  cartItems  CartItem[]
  orderItems OrderItem[]
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items     CartItem[]
}

model CartItem {
  id        String       @id @default(uuid())
  cartId    String
  cart      Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  foodId    String
  food      Food         @relation(fields: [foodId], references: [id])
  variantId String?
  variant   FoodVariant? @relation(fields: [variantId], references: [id])
  addonId   String?
  addon     FoodAddon?   @relation(fields: [addonId], references: [id])
  quantity  Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY_FOR_PICKUP
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

model Order {
  id                String       @id @default(uuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id])
  restaurantId      String
  restaurant        Restaurant   @relation(fields: [restaurantId], references: [id])
  deliveryAddressId String
  address           Address      @relation(fields: [deliveryAddressId], references: [id])
  status            OrderStatus  @default(PENDING)
  itemTotal         Float
  taxAmount         Float
  deliveryFee       Float
  discountAmount    Float        @default(0)
  totalAmount       Float
  specialInstructions String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  items             OrderItem[]
  payment           Payment?
  delivery          Delivery?
  couponUsage       CouponUsage[]
}

model OrderItem {
  id        String       @id @default(uuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  foodId    String
  food      Food         @relation(fields: [foodId], references: [id])
  variantId String?
  variant   FoodVariant? @relation(fields: [variantId], references: [id])
  addonId   String?
  addon     FoodAddon?   @relation(fields: [addonId], references: [id])
  quantity  Int
  price     Float        // Price at the time of order
  createdAt DateTime     @default(now())
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  COD
  RAZORPAY
}

model Payment {
  id            String        @id @default(uuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id])
  amount        Float
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?       @unique // E.g., Razorpay payment ID
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  refund        Refund?
}

model Refund {
  id            String   @id @default(uuid())
  paymentId     String   @unique
  payment       Payment  @relation(fields: [paymentId], references: [id])
  amount        Float
  reason        String?
  status        String   // 'PENDING', 'COMPLETED', 'FAILED'
  transactionId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DeliveryPartner {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleType     String
  vehicleNumber   String
  isAvailable     Boolean  @default(true)
  currentLatitude Float?
  currentLongitude Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deliveries      Delivery[]
  locations       DeliveryLocation[]
}

enum DeliveryStatus {
  ASSIGNED
  AT_RESTAURANT
  PICKED_UP
  ON_THE_WAY
  DELIVERED
  CANCELLED
}

model Delivery {
  id                String          @id @default(uuid())
  orderId           String          @unique
  order             Order           @relation(fields: [orderId], references: [id])
  deliveryPartnerId String
  partner           DeliveryPartner @relation(fields: [deliveryPartnerId], references: [id])
  status            DeliveryStatus  @default(ASSIGNED)
  earnings          Float           @default(0)
  pickupTime        DateTime?
  dropoffTime       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model DeliveryLocation {
  id                String          @id @default(uuid())
  deliveryPartnerId String
  partner           DeliveryPartner @relation(fields: [deliveryPartnerId], references: [id], onDelete: Cascade)
  latitude          Float
  longitude         Float
  timestamp         DateTime        @default(now())
}

model Review {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id])
  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])
  foodId       String?
  food         Food?       @relation(fields: [foodId], references: [id])
  rating       Int         // 1 to 5
  comment      String?
  createdAt    DateTime    @default(now())
}

model Coupon {
  id             String        @id @default(uuid())
  code           String        @unique
  description    String?
  discountType   String        // 'PERCENTAGE', 'FIXED'
  discountValue  Float
  minOrderValue  Float         @default(0)
  maxDiscount    Float?
  validFrom      DateTime
  validUntil     DateTime
  isActive       Boolean       @default(true)
  maxUsesPerUser Int           @default(1)
  totalUsesLimit Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  usages         CouponUsage[]
}

model CouponUsage {
  id        String   @id @default(uuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id])
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String   // 'ORDER', 'PROMO', 'SYSTEM'
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String   // e.g., 'Restaurant', 'Order'
  entityId  String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())
}
